# WebSocket Server Configuration
WEBSOCKET_HOST=localhost    # Hostname or IP of the WebSocket server
WEBSOCKET_PORT=8080        # Port of the WebSocket server
WEBSOCKET_PATH=ws          # WebSocket endpoint path

# Logging
LOG_LEVEL=INFO            # Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)

# Behavior
RECONNECT_DELAY=5.0       # Delay in seconds between reconnection attempts
